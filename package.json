{
  "name": "cins-website",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 111",
    "firefox >= 111",
    "safari >= 16.4",
    "edge >= 111"
  ],
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "clear-browser-cache": "node scripts/clear-cursor-browser-cache.mjs",
    "dev": "next dev -p 3001",
    "host": "node scripts/dev-host.mjs",
    "host:webpack": "node scripts/dev-host.mjs --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "preview": "node scripts/ensure-prod-site-url.mjs \"opennextjs-cloudflare build && opennextjs-cloudflare preview\"",
    "deploy": "node scripts/ensure-prod-site-url.mjs \"opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars\"",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:variants": "node scripts/cf-ensure-image-variants.mjs",
    "backfill:diem-feed": "node scripts/backfill-content-diem-feed.mjs"
  },
  "dependencies": {
    "@rive-app/canvas": "^2.38.3",
    "@rive-app/react-canvas": "^4.29.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-table-cell": "^3.23.4",
    "@tiptap/extension-table-header": "^3.23.4",
    "@tiptap/extension-table-row": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/extension-youtube": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.16.0",
    "mage-icons-react": "^0.7.0-beta",
    "next": "^16.2.9",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-feather": "^2.0.10",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.105.0"
  }
}
